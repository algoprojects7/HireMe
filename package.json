{
  "name": "unorganized-workers",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky install",
    "studio": "prisma studio --schema packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "turbo": "^1.10.15",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2",
    "eslint": "^8.48.0",
    "husky": "^8.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
