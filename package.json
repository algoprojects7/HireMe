{
  "name": "unorganized-workers",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "generate": "pnpm --filter @repo/database db:generate",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean && rimraf --glob node_modules .turbo apps/**/.next apps/**/.turbo packages/**/.turbo",
    "prepare": "husky install",
    "studio": "prisma studio --schema packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "eslint": "^8.48.0",
    "husky": "^8.0.3",
    "prettier": "^3.0.3",
    "rimraf": "^6.1.3",
    "turbo": "^1.10.15",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@8.15.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
